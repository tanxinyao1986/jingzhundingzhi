/* ========================================
   诊断页样式 - 八字五行推算
   ======================================== */

page {
  background-color: #F9F7F2;
}

.page-container {
  min-height: 100vh;
  background-color: #F9F7F2;
  padding-bottom: 120rpx;
}

/* 页面头部 */
.page-header {
  padding: 60rpx 40rpx 40rpx;
  text-align: center;
  background: linear-gradient(180deg, #F2EFE9 0%, #F9F7F2 100%);
}

.header-ornament {
  font-size: 28rpx;
  color: #D4AF37;
  margin-bottom: 16rpx;
}

.header-title {
  font-size: 48rpx;
  font-weight: 500;
  color: #8E7F73;
  font-family: 'Songti SC', 'Noto Serif SC', serif;
  letter-spacing: 8rpx;
  margin-bottom: 16rpx;
}

.header-subtitle {
  font-size: 24rpx;
  color: #B5A496;
  font-family: 'Songti SC', serif;
  letter-spacing: 2rpx;
}

/* 表单卡片 */
.form-card {
  margin: 24rpx 32rpx;
  background: #F2EFE9;
  border-radius: 28rpx;
  padding: 16rpx 36rpx;
  border: 1rpx solid rgba(180, 164, 150, 0.3);
}

/* 历法切换 */
.calendar-toggle {
  display: flex;
  background: #E8E3DC;
  border-radius: 20rpx;
  padding: 6rpx;
  margin: 20rpx 0 16rpx;
}

.toggle-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #B5A496;
  font-family: 'Songti SC', serif;
  letter-spacing: 2rpx;
  transition: all 0.2s;
}

.toggle-btn--active {
  background: #F9F7F2;
  color: #8E7F73;
  font-weight: 500;
  box-shadow: 0 2rpx 8rpx rgba(142, 127, 115, 0.15);
}

/* 表单行 */
.form-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 0;
}

.form-label {
  font-size: 28rpx;
  color: #8E7F73;
  font-family: 'Songti SC', serif;
  letter-spacing: 1rpx;
}

.picker-value {
  font-size: 30rpx;
  color: #6B5E54;
  font-weight: 500;
  font-family: 'Songti SC', serif;
  padding: 8rpx 24rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 12rpx;
}

.form-divider {
  height: 1rpx;
  background: rgba(180, 164, 150, 0.3);
}

/* 不知道时辰 */
.unknown-hour {
  display: flex;
  align-items: center;
  padding: 24rpx 0 20rpx;
}

.checkbox {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #B5A496;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  font-size: 22rpx;
  color: #8E7F73;
}

.checkbox--checked {
  background: #8E7F73;
  border-color: #8E7F73;
  color: #F9F7F2;
}

.unknown-label {
  font-size: 24rpx;
  color: #B5A496;
}

/* 提示文字 */
.form-tip {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 36rpx;
  margin: 0 32rpx;
}

.tip-icon {
  font-size: 20rpx;
  color: #D4AF37;
  margin-right: 12rpx;
  margin-top: 4rpx;
  flex-shrink: 0;
}

.tip-text {
  font-size: 22rpx;
  color: #B5A496;
  line-height: 1.7;
}

/* 计算按钮 */
.submit-area {
  padding: 32rpx 32rpx 20rpx;
}

.btn-calculate {
  background: linear-gradient(135deg, #8E7F73 0%, #6B5E54 100%);
  color: #F9F7F2;
  border-radius: 100rpx;
  padding: 32rpx;
  font-size: 32rpx;
  font-weight: 500;
  font-family: 'Songti SC', serif;
  letter-spacing: 4rpx;
  border: none;
  text-align: center;
  display: block;
  width: 100%;
}

.btn-calculate::after {
  border: none;
}

/* ===== 结果区域 ===== */
.result-section {
  animation: fadeInUp 0.5s ease;
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(40rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.result-card {
  margin: 16rpx 32rpx;
  background: #F2EFE9;
  border-radius: 28rpx;
  padding: 36rpx;
  border: 1rpx solid rgba(180, 164, 150, 0.25);
}

.result-card--highlight {
  background: linear-gradient(145deg, #EDE8E1 0%, #F2EFE9 100%);
  border-color: rgba(212, 175, 55, 0.3);
}

.result-card-title {
  font-size: 26rpx;
  color: #D4AF37;
  font-family: 'Songti SC', serif;
  letter-spacing: 4rpx;
  margin-bottom: 28rpx;
  display: flex;
  align-items: center;
}

.title-icon {
  margin-right: 8rpx;
}

/* 四柱表格 */
.bazi-grid {
  display: flex;
  justify-content: space-around;
  margin-bottom: 20rpx;
}

.pillar {
  flex: 1;
  text-align: center;
  padding: 16rpx 8rpx;
  background: rgba(255, 255, 255, 0.5);
  border-radius: 16rpx;
  margin: 0 6rpx;
}

.pillar-label {
  font-size: 20rpx;
  color: #B5A496;
  margin-bottom: 12rpx;
  letter-spacing: 1rpx;
}

.pillar-stem {
  font-size: 40rpx;
  color: #8E7F73;
  font-weight: 500;
  font-family: 'Songti SC', serif;
  line-height: 1;
  margin-bottom: 4rpx;
}

.pillar-branch {
  font-size: 40rpx;
  color: #6B5E54;
  font-family: 'Songti SC', serif;
  line-height: 1;
  margin-bottom: 8rpx;
}

.pillar-element {
  font-size: 20rpx;
  font-weight: 500;
}

.pillar-element-branch {
  font-size: 20rpx;
  opacity: 0.8;
}

.bazi-string {
  text-align: center;
  font-size: 22rpx;
  color: #B5A496;
  letter-spacing: 3rpx;
  font-family: 'Songti SC', serif;
}

/* 五行分布柱状图 */
.elements-bar {
  display: flex;
  justify-content: space-around;
  align-items: flex-end;
  height: 200rpx;
  padding-top: 20rpx;
}

.element-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.element-bar-wrap {
  height: 120rpx;
  display: flex;
  align-items: flex-end;
  margin-bottom: 8rpx;
}

.element-bar-fill {
  width: 32rpx;
  border-radius: 8rpx 8rpx 0 0;
  min-height: 8rpx;
  transition: height 0.8s ease;
}

.element-emoji {
  font-size: 28rpx;
  margin-bottom: 4rpx;
}

.element-name {
  font-size: 22rpx;
  color: #8E7F73;
  font-family: 'Songti SC', serif;
}

.element-count {
  font-size: 18rpx;
  color: #B5A496;
  margin-top: 2rpx;
}

/* 诊断报告 */
.method-badge {
  display: inline-block;
  background: rgba(212, 175, 55, 0.15);
  color: #D4AF37;
  font-size: 20rpx;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(212, 175, 55, 0.3);
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
}

.method-detail {
  font-size: 24rpx;
  color: #B5A496;
  line-height: 1.7;
  margin-bottom: 20rpx;
}

.report-divider {
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(212, 175, 55, 0.4), transparent);
  margin: 24rpx 0;
}

/* 推荐五行 */
.recommend-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
  margin-bottom: 28rpx;
}

.recommend-item {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  border-radius: 20rpx;
}

.recommend-item--main {
  background: rgba(255, 255, 255, 0.5);
}

.recommend-item--assist {
  background: rgba(255, 255, 255, 0.3);
}

.recommend-label {
  font-size: 20rpx;
  color: #B5A496;
  letter-spacing: 2rpx;
  margin-bottom: 12rpx;
}

.recommend-element {
  font-size: 32rpx;
  font-weight: 500;
  font-family: 'Songti SC', serif;
  margin-bottom: 8rpx;
}

.recommend-desc {
  font-size: 20rpx;
  color: #B5A496;
}

.recommend-divider {
  font-size: 24rpx;
  color: #D4AF37;
  opacity: 0.5;
  padding: 0 8rpx;
}

.report-text {
  font-size: 24rpx;
  color: #8E7F73;
  line-height: 2;
  font-family: 'Songti SC', serif;
  white-space: pre-line;
}

/* 下一步按钮 */
.next-step-area {
  padding: 24rpx 32rpx 8rpx;
}

.btn-gold-next {
  background: linear-gradient(135deg, #D4AF37 0%, #F0D060 50%, #D4AF37 100%);
  color: #5C4A00;
  border-radius: 100rpx;
  padding: 32rpx;
  font-size: 30rpx;
  font-weight: 500;
  font-family: 'Songti SC', serif;
  letter-spacing: 4rpx;
  border: none;
  text-align: center;
  display: block;
  width: 100%;
}

.btn-gold-next::after {
  border: none;
}

.disclaimer {
  font-size: 20rpx;
  color: #B5A496;
  text-align: center;
  padding: 16rpx 40rpx 40rpx;
  opacity: 0.7;
}
