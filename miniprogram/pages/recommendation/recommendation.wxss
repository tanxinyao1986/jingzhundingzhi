page { background-color: #F9F7F2; }

.page-container { min-height: 100vh; padding-bottom: 120rpx; }

.page-header {
  padding: 60rpx 40rpx 32rpx;
  text-align: center;
  background: linear-gradient(180deg, #F2EFE9 0%, #F9F7F2 100%);
}
.header-ornament { font-size: 28rpx; color: #D4AF37; margin-bottom: 12rpx; }
.header-title {
  font-size: 48rpx; font-weight: 500; color: #8E7F73;
  font-family: 'Songti SC', serif; letter-spacing: 8rpx; margin-bottom: 16rpx;
}
.header-element { font-size: 30rpx; font-weight: 500; font-family: 'Songti SC', serif; }

.section-label {
  font-size: 26rpx; color: #D4AF37; letter-spacing: 4rpx;
  padding: 28rpx 40rpx 16rpx; font-family: 'Songti SC', serif;
}

.crystal-list { padding: 0 32rpx; }

.crystal-card {
  background: #F2EFE9; border-radius: 24rpx; padding: 28rpx;
  margin-bottom: 20rpx; display: flex; align-items: center;
  border: 1rpx solid rgba(180, 164, 150, 0.3);
}

.crystal-img {
  width: 120rpx; height: 120rpx; border-radius: 50%;
  flex-shrink: 0; margin-right: 28rpx;
  overflow: hidden;
}

.crystal-info { flex: 1; }
.crystal-name { font-size: 30rpx; color: #8E7F73; font-weight: 500; font-family: 'Songti SC', serif; margin-bottom: 8rpx; }
.crystal-element { font-size: 22rpx; color: #B5A496; margin-bottom: 12rpx; }
.crystal-keywords { display: flex; flex-wrap: wrap; gap: 8rpx; margin-bottom: 12rpx; }
.keyword {
  font-size: 20rpx; color: #8E7F73; background: rgba(142,127,115,0.1);
  padding: 4rpx 16rpx; border-radius: 20rpx;
}
.crystal-price { font-size: 28rpx; color: #D4AF37; font-weight: 500; }
.crystal-add {
  width: 60rpx; height: 60rpx; border-radius: 50%;
  background: #8E7F73; color: #F9F7F2;
  display: flex; align-items: center; justify-content: center;
  font-size: 40rpx; flex-shrink: 0; margin-left: 16rpx;
}

.diy-cta { margin: 32rpx; text-align: center; }
.diy-cta-text { font-size: 24rpx; color: #B5A496; margin-bottom: 20rpx; font-family: 'Songti SC', serif; }
.btn-go-diy {
  background: linear-gradient(135deg, #D4AF37, #F0D060);
  color: #5C4A00; border-radius: 100rpx; padding: 32rpx;
  font-size: 30rpx; font-weight: 500; font-family: 'Songti SC', serif;
  letter-spacing: 2rpx; border: none; display: block; width: 100%;
}
.btn-go-diy::after { border: none; }
.disclaimer { font-size: 20rpx; color: #B5A496; text-align: center; padding: 16rpx 40rpx 40rpx; opacity: 0.7; }
